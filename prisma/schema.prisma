// deliverGO — Prisma schema
// See IMPLEMENTATION.md Phase 1 and ARCHITECTURE.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STORE_MANAGER
  DINER
}

enum DeliveryStatus {
  draft
  pending
  scheduled
  en_route_to_pickup
  arrived_at_pickup
  en_route_to_dropoff
  arrived_at_dropoff
  completed
  cancelled
  failed
}

model Store {
  id           String   @id @default(cuid())
  name         String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  province     String
  postalCode   String
  country      String   @default("CA")
  latitude     Float
  longitude    Float
  enabledUberDirect       Boolean  @default(true)
  enabledDoorDashDrive    Boolean  @default(true)
  doordashExternalStoreId String?
  /// Typical kitchen prep time shown on guest tracking (minutes).
  prepMinutes             Int      @default(25)
  whatsappEnabled         Boolean  @default(false)
  whatsappPhoneNumberId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users                 User[]
  deliveries            Delivery[]
  customers             Customer[]
  whatsappStaffPhones   WhatsAppStaffPhone[]
  whatsappConversations WhatsAppConversation[]
  menuCategories        MenuCategory[]
  menuItems             MenuItem[]
  carts                 Cart[]
  orders                Order[]
  hours                 StoreHours[]
}

/// Weekly open/closed schedule (store-local timezone via STORE_TIMEZONE).
model StoreHours {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  /// 0 = Sunday … 6 = Saturday (JS Date.getDay)
  dayOfWeek   Int
  closed      Boolean  @default(false)
  /// Minutes from midnight (0–1439). Null when closed.
  openMinute  Int?
  /// Minutes from midnight (0–1439). May be less than openMinute for overnight.
  closeMinute Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeId, dayOfWeek])
  @@index([storeId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phoneE164    String?
  role         UserRole @default(STORE_MANAGER)
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  passwordResetTokens PasswordResetToken[]

  @@index([storeId])
  @@index([storeId, role])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([userId, createdAt(sort: Desc)])
}

model Customer {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phones     CustomerPhone[]
  addresses  CustomerAddress[]
  deliveries Delivery[]

  @@index([storeId, updatedAt(sort: Desc)])
  @@index([storeId, name])
}

model CustomerPhone {
  id         String   @id @default(cuid())
  storeId    String
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  phoneE164  String
  label      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([storeId, phoneE164])
  @@index([customerId])
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  line1      String
  line2      String?
  city       String
  province   String
  postalCode String
  country    String   @default("CA")
  latitude   Float
  longitude  Float
  formatted  String
  label      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([customerId, postalCode, line1])
}

model Delivery {
  id                 String         @id @default(cuid())
  externalId         String         @unique
  storeId            String
  store              Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerId         String?
  customer           Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  providerId         String         @default("uber_direct")
  providerDeliveryId String?
  providerOrderId    String?
  quoteId            String?
  orderId            String?
  providerPayload    Json?
  pickupName         String
  pickupPhone        String
  pickupAddress      String
  pickupLat          Float
  pickupLng          Float
  dropoffName        String
  dropoffPhone       String
  dropoffAddress     String
  dropoffLat         Float
  dropoffLng         Float
  feeCents           Int?
  currency           String         @default("CAD")
  status             DeliveryStatus @default(draft)
  trackingUrl        String?
  pickupReadyAt      DateTime?
  scheduledFor       DateTime?
  podSignature       Boolean        @default(false)
  podPicture         Boolean        @default(true)
  podPincode         Boolean        @default(false)
  proofOfDelivery    Json?
  cancelledAt        DateTime?
  cancelReason       String?
  cancelledBy        String?
  liveMode           Boolean        @default(false)
  source             String         @default("dashboard")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  webhookEvents WebhookEvent[]
  restaurantOrder Order?

  @@index([storeId, createdAt(sort: Desc)])
  @@index([customerId])
  @@index([providerDeliveryId])
  @@index([status])
}

model WebhookEvent {
  id          String    @id @default(cuid())
  eventId     String    @unique
  eventType   String
  payload     Json
  processedAt DateTime?
  deliveryId  String?
  delivery    Delivery? @relation(fields: [deliveryId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([deliveryId])
}

model WhatsAppStaffPhone {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  phoneE164 String
  label     String?
  createdAt DateTime @default(now())

  @@unique([storeId, phoneE164])
  @@index([storeId])
}

model WhatsAppConversation {
  id             String   @id @default(cuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staffPhoneE164 String
  state          String   @default("idle")
  payload        Json     @default("{}")
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([storeId, staffPhoneE164])
  @@index([storeId, staffPhoneE164])
}

// ---------------------------------------------------------------------------
// Restaurant ordering (v3) — see RESTAURANT_IMPLEMENTATION.md
// ---------------------------------------------------------------------------

enum FulfillmentType {
  pickup
  delivery
}

enum FulfillmentMethod {
  unassigned
  delivergo
  manual
}

enum OrderStatus {
  pending_payment
  pending_acceptance
  accepted
  preparing
  ready
  ready_for_pickup
  out_for_delivery
  completed
  cancelled
}

model MenuCategory {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MenuItem[]

  @@index([storeId, sortOrder])
}

model MenuItem {
  id          String       @id @default(cuid())
  storeId     String
  store       Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?
  priceCents  Int
  imageUrl    String?
  available   Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  modifierGroups MenuModifierGroup[]
  cartItems      CartItem[]

  @@index([categoryId, sortOrder])
  @@index([storeId, available])
}

model MenuModifierGroup {
  id        String   @id @default(cuid())
  itemId    String
  item      MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name      String
  required  Boolean  @default(false)
  minSelect Int      @default(0)
  maxSelect Int      @default(1)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modifiers MenuModifier[]

  @@index([itemId, sortOrder])
}

model MenuModifier {
  id             String           @id @default(cuid())
  groupId        String
  group          MenuModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name           String
  priceDeltaCents Int             @default(0)
  available      Boolean          @default(true)
  sortOrder      Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([groupId, sortOrder])
}

model Cart {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sessionId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CartItem[]

  @@unique([storeId, sessionId])
  @@index([sessionId])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem  MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  /// Selected modifier ids + labels/prices snapshot for display
  modifiers Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
  @@index([menuItemId])
}

model Order {
  id                   String            @id @default(cuid())
  storeId              String
  store                Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId               String?
  user                 User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  publicToken          String            @unique @default(cuid())
  status               OrderStatus       @default(pending_payment)
  fulfillmentType      FulfillmentType
  fulfillmentMethod    FulfillmentMethod @default(unassigned)
  customerName         String
  customerPhone        String
  dropoffAddress       String?
  dropoffLat           Float?
  dropoffLng           Float?
  /// Guest scheduled ready/pickup time (next open when store is closed).
  scheduledFor         DateTime?
  subtotalCents        Int
  tipCents             Int               @default(0)
  taxCents             Int               @default(0)
  totalCents           Int
  currency             String            @default("CAD")
  squarePaymentId      String?           @unique
  manualDeliveryNote   String?
  deliveryId           String?           @unique
  delivery             Delivery?         @relation(fields: [deliveryId], references: [id], onDelete: SetNull)
  notes                String?
  placedAt             DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  lineItems OrderLineItem[]
  events    OrderEvent[]

  @@index([storeId, createdAt(sort: Desc)])
  @@index([storeId, status])
  @@index([publicToken])
  @@index([userId, createdAt(sort: Desc)])
}

model OrderLineItem {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  unitPriceCents  Int
  quantity        Int
  /// Snapshot of selected modifiers at purchase time
  modifiers       Json     @default("[]")
  lineTotalCents  Int
  menuItemId      String?
  createdAt       DateTime @default(now())

  @@index([orderId])
}

model OrderEvent {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  actor     String
  note      String?
  createdAt DateTime    @default(now())

  @@index([orderId, createdAt(sort: Asc)])
}
