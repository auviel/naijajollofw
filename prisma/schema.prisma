// deliverGO — Prisma schema
// See IMPLEMENTATION.md Phase 1 and ARCHITECTURE.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STORE_MANAGER
}

enum DeliveryStatus {
  draft
  pending
  scheduled
  en_route_to_pickup
  arrived_at_pickup
  en_route_to_dropoff
  arrived_at_dropoff
  completed
  cancelled
  failed
}

model Store {
  id           String   @id @default(cuid())
  name         String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  province     String
  postalCode   String
  country      String   @default("CA")
  latitude     Float
  longitude    Float
  enabledUberDirect       Boolean  @default(true)
  enabledDoorDashDrive    Boolean  @default(true)
  doordashExternalStoreId String?
  whatsappEnabled         Boolean  @default(false)
  whatsappPhoneNumberId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users                 User[]
  deliveries            Delivery[]
  customers             Customer[]
  whatsappStaffPhones   WhatsAppStaffPhone[]
  whatsappConversations WhatsAppConversation[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(STORE_MANAGER)
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([storeId])
}

model Customer {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phones     CustomerPhone[]
  addresses  CustomerAddress[]
  deliveries Delivery[]

  @@index([storeId, updatedAt(sort: Desc)])
  @@index([storeId, name])
}

model CustomerPhone {
  id         String   @id @default(cuid())
  storeId    String
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  phoneE164  String
  label      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([storeId, phoneE164])
  @@index([customerId])
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  line1      String
  line2      String?
  city       String
  province   String
  postalCode String
  country    String   @default("CA")
  latitude   Float
  longitude  Float
  formatted  String
  label      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([customerId, postalCode, line1])
}

model Delivery {
  id                 String         @id @default(cuid())
  externalId         String         @unique
  storeId            String
  store              Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerId         String?
  customer           Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  providerId         String         @default("uber_direct")
  providerDeliveryId String?
  providerOrderId    String?
  quoteId            String?
  orderId            String?
  providerPayload    Json?
  pickupName         String
  pickupPhone        String
  pickupAddress      String
  pickupLat          Float
  pickupLng          Float
  dropoffName        String
  dropoffPhone       String
  dropoffAddress     String
  dropoffLat         Float
  dropoffLng         Float
  feeCents           Int?
  currency           String         @default("CAD")
  status             DeliveryStatus @default(draft)
  trackingUrl        String?
  pickupReadyAt      DateTime?
  scheduledFor       DateTime?
  podSignature       Boolean        @default(false)
  podPicture         Boolean        @default(true)
  podPincode         Boolean        @default(false)
  proofOfDelivery    Json?
  cancelledAt        DateTime?
  cancelReason       String?
  cancelledBy        String?
  liveMode           Boolean        @default(false)
  source             String         @default("dashboard")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  webhookEvents WebhookEvent[]

  @@index([storeId, createdAt(sort: Desc)])
  @@index([customerId])
  @@index([providerDeliveryId])
  @@index([status])
}

model WebhookEvent {
  id          String    @id @default(cuid())
  eventId     String    @unique
  eventType   String
  payload     Json
  processedAt DateTime?
  deliveryId  String?
  delivery    Delivery? @relation(fields: [deliveryId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([deliveryId])
}

model WhatsAppStaffPhone {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  phoneE164 String
  label     String?
  createdAt DateTime @default(now())

  @@unique([storeId, phoneE164])
  @@index([storeId])
}

model WhatsAppConversation {
  id             String   @id @default(cuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staffPhoneE164 String
  state          String   @default("idle")
  payload        Json     @default("{}")
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([storeId, staffPhoneE164])
  @@index([storeId, staffPhoneE164])
}
