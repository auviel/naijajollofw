# App
DATABASE_URL="postgresql://delivergo:delivergo@localhost:5433/delivergo?schema=public"
# Neon (Vercel): use pooled URL for DATABASE_URL, direct URL for migrations if using Prisma directUrl
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Uber Direct (sandbox credentials from https://direct.uber.com → Developer tab)
UBER_CLIENT_ID=""
UBER_CLIENT_SECRET=""
UBER_CUSTOMER_ID=""
UBER_API_BASE="https://api.uber.com"
# false = sandbox + robo courier on delivery create (default)
UBER_LIVE_MODE="false"
# Optional — defaults to America/Toronto for date/time display
# STORE_TIMEZONE="America/Toronto"
# Webhook signing key from Uber Developer Dashboard → Settings → Ride Requests.
# Falls back to UBER_CLIENT_SECRET when empty.
UBER_WEBHOOK_SIGNING_SECRET=""

# DoorDash Drive (credentials from https://developer.doordash.com → Drive)
DOORDASH_DEVELOPER_ID=""
DOORDASH_KEY_ID=""
DOORDASH_SIGNING_SECRET=""
DOORDASH_EXTERNAL_BUSINESS_ID=""
DOORDASH_EXTERNAL_STORE_ID="default"
# Set to true after DoorDash Canada sandbox is approved
DOORDASH_ENABLED="false"
DOORDASH_API_BASE="https://openapi.doordash.com"
DOORDASH_LIVE_MODE="false"
# Optional Authorization header value configured in DoorDash webhook settings
DOORDASH_WEBHOOK_AUTHORIZATION=""

# Geocoding (Mapbox — Canada-biased)
MAPBOX_ACCESS_TOKEN=""

# Public storefront (single restaurant). Falls back to first Store in DB.
# PUBLIC_STORE_ID="seed-store-waterloo"

# Square (restaurant checkout — Phase R3)
# Create an app at https://developer.squareup.com → Credentials
SQUARE_ACCESS_TOKEN=""
SQUARE_LOCATION_ID=""
SQUARE_ENVIRONMENT="sandbox"
# Webhook signature key + exact notification URL from Square Developer Dashboard
SQUARE_WEBHOOK_SIGNATURE_KEY=""
# Optional override; defaults to NEXT_PUBLIC_APP_URL/api/webhooks/square
# SQUARE_WEBHOOK_NOTIFICATION_URL="https://your-domain.com/api/webhooks/square"
NEXT_PUBLIC_SQUARE_APPLICATION_ID=""
NEXT_PUBLIC_SQUARE_LOCATION_ID=""
# Tax rate in basis points (1300 = 13% Ontario HST). Tax applies to food subtotal only.
TAX_RATE_BPS="1300"

# WhatsApp Cloud API (Meta — Phase 15 staff dispatch)
WHATSAPP_ENABLED="false"
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_API_VERSION="v25.0"
# Comma-separated staff phones allowed to dispatch (E.164). Required for webhook auth.
WHATSAPP_STAFF_PHONES=""
# Opt-in diner order status texts (separate from staff dispatch). Requires WHATSAPP_ENABLED.
WHATSAPP_ORDER_UPDATES="false"
# Optional — defaults to first store in DB (seed-store-waterloo in dev)
# WHATSAPP_STORE_ID="seed-store-waterloo"
